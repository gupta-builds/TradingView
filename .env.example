# Copy to .env and fill in. Never commit .env.

# Prices — Massive.com (formerly Polygon.io). NOT polygon.technology (blockchain).
# Dashboard: https://massive.com/dashboard/api-keys
# Either name works; POLYGON_API_KEY is what config/providers.toml reads.
POLYGON_API_KEY=
# MASSIVE_API_KEY=

# Fundamentals (Financial Modeling Prep)
FMP_API_KEY=

# SEC EDGAR identity header (not a secret key — required on every SEC request)
# Format: AppName your.email@example.com
SEC_USER_AGENT=

# Optional backups (not required for the year-ahead base)
# TIINGO_API_KEY=
# ALPHA_VANTAGE_API_KEY=

# --- Phase 3 AI hub (litellm; keys never committed) ---
# RESEARCH_DATA_LLM=fixture|live  (CI/default = fixture; live smoke = live)
RESEARCH_DATA_LLM=fixture
# Documented live default: Gemini Flash free tier (confirm current alias at implement time).
# Note: Google's free tier may use prompts for product improvement / training —
# low-stakes for public market summary packets, stated explicitly here.
LLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=
# Alternate free-tier path (Groq)
# LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
# Optional local fallback for litellm.Router
# OLLAMA_API_BASE=http://localhost:11434
