# Copy to .env and fill in. Never commit .env.

# Prices — Massive.com (formerly Polygon.io). NOT polygon.technology (blockchain).
# Dashboard: https://massive.com/dashboard/api-keys
# Either name works; POLYGON_API_KEY is what config/providers.toml reads.
POLYGON_API_KEY=
# MASSIVE_API_KEY=

# Fundamentals (Financial Modeling Prep)
FMP_API_KEY=

# SEC EDGAR identity header (not a secret key — required on every SEC request)
# Format: AppName your.email@example.com
SEC_USER_AGENT=

# Optional backups (not required for the year-ahead base)
# TIINGO_API_KEY=
# ALPHA_VANTAGE_API_KEY=
