{
  "permissions": {
    "allow": [
      "Bash(pytest *)",
      "Bash(pytest)",
      "Bash(python -m pytest *)",
      "Bash(pip install -e .)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git show *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-secrets.sh",
            "statusMessage": "Checking for secrets before git commit/push..."
          }
        ]
      }
    ]
  }
}
